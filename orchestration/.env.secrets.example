# orchestration/.env.secrets.example
# ── Committed example for .env.secrets ───────────────────────────────────────
# Copy to .env.secrets and fill in real values.
# Generate a fernet key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__WEBSERVER__SECRET_KEY=
_AIRFLOW_WWW_USER_USERNAME=
_AIRFLOW_WWW_USER_PASSWORD=
AIRFLOW_CONN_GOOGLE_CLOUD_DEFAULT="google-cloud-platform://?extra__google_cloud_platform__project=passculture-data-ehp&extra__google_cloud_platform__scope=https://www.googleapis.com/auth/cloud-platform"