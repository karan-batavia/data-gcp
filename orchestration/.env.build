# orchestration/.env.build
# ── Build & cluster bootstrap variables ──────────────────────────────────────
# Loaded by the Makefile via `-include .env.build`.
# Never injected into pods — Makefile/Docker use only.
# Copy from .env.build.example and adjust to your machine.

REGISTRY=localhost:5001
TAG=dev
KIND_CLUSTER=airflow
NETWORK_MODE=proxy